{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cozmio",
  "version": "0.1.0",
  "identifier": "com.cozmio.app",
  "build": {
    "frontendDist": "../src-tauri/src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "Cozmio - 主动智能体",
        "width": 900,
        "height": 650,
        "resizable": true,
        "visible": true,
        "center": true,
        "minimizable": true,
        "closable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "dialog": null,
    "notification": null
  }
}